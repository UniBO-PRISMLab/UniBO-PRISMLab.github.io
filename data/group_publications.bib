@inproceedings{abuoda2024mascots2024,
  title = {MASCOTS 2024},
  author = {Ghadeer Abuoda and Lydia Ait Oucheggou and Mahnoor Anjum and Iury Araujo and Enrico Barbierato and Lukas Beierlieb and Nabila Bermad and Pasquale Cascarano and Aris Castillo and David Cortes and Marco Di Felice and Joanna Georgiou and Amus Chee Yuen Goay and Charles Goncalves and Michalis Kasioulis and Purushottam Kulkarni and Vincent Lannurien and Junye Li and Moreno Marzolla and Mohand Moktefi and Abhishek Mondal and Federico Montori and Roman Pletka and Andrea Pozzi and Thomas Prantl and Yessad Samira and Slavisa Sarafijanovic and Lorenzo Stacchio and Michael Stenger and Martin Straesser and Matheus Torquato and Animesh Trivedi and Angelo Trotta and Mythili Vutukuru and Salah Zemmoudj and Yijia Zhang},
  year = {2024},
  booktitle = {IEEE/ACM International Symposium on Modeling, Analysis, and Simulation On Computer and Telecommunication Systems},
  doi = {10.1109/mascots64422.2024.10786562},
