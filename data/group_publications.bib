  author = {Luciano Bononi and Albert Y Zomaya},
  year = {2008},
  journal = {Computer Communications},
  url = {https://cris.unibo.it/handle/11585/81536},
  abstract = {Wireless communications technology is enjoying its fastest growth period in history. This unprecedented growth continues to affect the way we live, work and play by contributing to the origins of the ‘‘Era of mobile wireless access”. Yet solutions for mobile wireless access are still in the early stages of development. The main activities of research include architectures, technologies, protocols and services support for mobile communications, mobile computing and wireless access. This special issue brings together twelve contributions, with both theoretical and practical results of significance on all aspects of wireless and mobile access technologies, under different viewpoints, with an emphasis on Mobility Management and Wireless Access. The contributions include themes like the mobility-aware architectures, protocols and services, location based services, proximity detection, transport-layer mobility and multi-homing, multi-user sessions, wireless IP traffic modeling, context-aware service discovery, link-layer convergence, multi-channel technologies, vertical handoffs, radio data management, data gathering and convergecast, in the context of next generation wireless systems, sensor networks, Mobile IPv6 networks, ZigBee and wireless mesh networks. The papers have been selected from a total of more than 60 submitted papers, due to their originality and contribution to the field of wireless communications, with a particular emphasis on Mobility Management and Wireless Access–the theme of this special issue.},
}

