  url = {https://search.proquest.com/openview/1be0c92444ca97f4068db5623d647deb/1?pq-origsite=gscholar\&cbl=5046906},
  abstract = {Thanks to the great efforts of our reviewers, Drones was able to maintain its standards for the high quality of its published papers. The editors would like to extend their gratitude and recognition to the following reviewers for their precious time and dedication, regardless of whether the papers they reviewed were finally published: Abdelrahman Elsaid Konstantinos Topouzelis Abderrahmane Lakas Kotaro Hoshiba Abhijeet Ravankar Kristoffer Gryte Achilleas Tripolitsiotis Krzysztof Sibilski Adam Kiczko Krzysztof Skabek Adão Silva Kursat Kara Adi Azriff Basri Kye Adams Adiel Ismail Kyle Dunno Agoston Resta László Bertalan Ahmad Khan Laura Inzerillo Ahmad Taher Azar Laura Prosdocimi Ahmed Alamouri Le The Dung Ahmed El Oualkadi Leonardo De Mello Honório Aiguo Patrick Hu Leonardo Lecce Akos Kereszturi Leslie Wong Alaa AR Alsaeedy Linas Balčiauskas Alberto Martini Loïca Avanthey Alejandro …},
